#!/bin/bash

DATA_PLATFORM_DIR="$HOME/gw_code/data-platform"
MASTER_DIR="$DATA_PLATFORM_DIR/master"

# Fetch latest remote state (must run from inside a worktree)
cd "$MASTER_DIR" || { notify-send "Error" "Cannot access $MASTER_DIR"; exit 1; }
git fetch --prune --quiet 2>/dev/null

# List remote branches (strip origin/ prefix) for autocomplete
remote_branches=$(git branch -r --format='%(refname:short)' | sed 's|^origin/||' | sort)

# Prompt for branch name — remote branches shown as suggestions
branch=$(echo "$remote_branches" | walker --dmenu --placeholder "Branch name for new worktree")

[[ -z "$branch" ]] && exit 0

# Derive directory name: replace slashes with hyphens
dir_name="${branch//\//-}"
worktree_path="$DATA_PLATFORM_DIR/$dir_name"

# If worktree already exists, just open it
if [[ -d "$worktree_path" ]]; then
    notify-send "Worktree exists" "Opening $dir_name"
    code "$worktree_path"
    exit 0
fi

# Create worktree — must run from inside an existing worktree (master)
# The post-checkout hook at .bare/hooks/post-checkout handles setup:
#   - symlinks .env, .vscode, .tmp from master/
#   - runs uv sync --frozen to create .venv
if git branch -r --format='%(refname:short)' | grep -q "^origin/${branch}$"; then
    git worktree add "$worktree_path" "$branch"
else
    git worktree add "$worktree_path" -b "$branch"
fi

if [[ $? -ne 0 ]]; then
    notify-send "Worktree failed" "Could not create $dir_name"
    exit 1
fi

# Fallback: if the hook didn't run, set up manually
if [[ ! -L "$worktree_path/.env" && -f "$MASTER_DIR/.env" ]]; then
    ln -s "$MASTER_DIR/.env" "$worktree_path/.env"
fi
if [[ ! -d "$worktree_path/.venv" ]]; then
    notify-send "Worktree setup" "Running uv sync for $dir_name..."
    uv sync --frozen --directory "$worktree_path"
fi

notify-send "Worktree ready" "$dir_name"
code "$worktree_path"
