{{- $host := dict -}}
{{- if hasKey .hosts .chezmoi.hostname }}{{ $host = index .hosts .chezmoi.hostname }}{{ end -}}
{{- $host = merge $host .defaults -}}
{{- if eq $host.waybar.headset.impl "audeze-maxwell" -}}
#!/bin/bash
# Waybar module: Audeze Maxwell battery via headsetcontrol
#
# headsetcontrol occasionally returns BATTERY_UNAVAILABLE on a single HID read
# even when the headset is on, so retry a few times before giving up.

read_once() {
    # Use -b (battery-only) with -o json: querying all capabilities with plain
    # `-o json` causes the Audeze Maxwell battery read to return UNAVAILABLE.
    headsetcontrol -b -o json 2>/dev/null
}

level=-1
status=""
device=""

for _ in 1 2 3; do
    json=$(read_once)
    [[ -z "$json" ]] && continue
    device=$(echo "$json" | jq -r '.devices[0].device // empty')
    status=$(echo "$json" | jq -r '.devices[0].battery.status // empty')
    level=$(echo "$json" | jq -r '.devices[0].battery.level // -1')
    [[ "$status" == "BATTERY_AVAILABLE" || "$status" == "BATTERY_CHARGING" ]] && break
    sleep 0.3
done

icon="󰋋"

# No dongle at all
if [[ -z "$device" ]]; then
    echo "{\"text\": \"${icon}\", \"tooltip\": \"Audeze Maxwell dongle not detected\", \"class\": \"disconnected\"}"
    exit 0
fi

# Headset powered off / out of range
if [[ "$status" != "BATTERY_AVAILABLE" && "$status" != "BATTERY_CHARGING" ]]; then
    echo "{\"text\": \"${icon}\", \"tooltip\": \"${device}\\nOff or out of range\", \"class\": \"disconnected\"}"
    exit 0
fi

if [[ "$status" == "BATTERY_CHARGING" ]]; then
    echo "{\"text\": \"${icon} \uf0e7\", \"tooltip\": \"${device}\\nCharging\", \"class\": \"charging\"}"
    exit 0
fi

if (( level < 0 )); then
    echo "{\"text\": \"${icon}\", \"tooltip\": \"${device}\\nUnknown level\", \"class\": \"disconnected\"}"
    exit 0
fi

if (( level <= 10 )); then
    class="critical"
elif (( level <= 20 )); then
    class="warning"
else
    class="normal"
fi

echo "{\"text\": \"${icon} ${level}%\", \"tooltip\": \"${device}\\n${level}%\", \"class\": \"${class}\"}"
{{- else -}}
#!/bin/bash
# Waybar module: Bluetooth audio device battery via BlueZ
# Dynamically discovers connected audio devices (headset/headphones) exposing
# the org.bluez.Battery1 interface.

ICON="󰋋"

disconnected='{"text": "", "tooltip": "", "class": "disconnected"}'

# Extract device paths (not their children) from busctl tree
mapfile -t devices < <(
    busctl tree org.bluez 2>/dev/null \
        | grep -oP '/org/bluez/hci\d+/dev_[0-9A-F]{2}(?:_[0-9A-F]{2}){5}' \
        | sort -u
)

for path in "${devices[@]}"; do
    connected=$(busctl get-property org.bluez "$path" org.bluez.Device1 Connected 2>/dev/null | awk '{print $2}')
    [[ "$connected" != "true" ]] && continue

    icon=$(busctl get-property org.bluez "$path" org.bluez.Device1 Icon 2>/dev/null | sed -E 's/^s "//; s/"$//')
    [[ "$icon" != audio-* ]] && continue

    percent_raw=$(busctl get-property org.bluez "$path" org.bluez.Battery1 Percentage 2>/dev/null)
    [[ -z "$percent_raw" ]] && continue
    percent=$(echo "$percent_raw" | awk '{print $2}')
    [[ -z "$percent" ]] && continue

    name=$(busctl get-property org.bluez "$path" org.bluez.Device1 Alias 2>/dev/null | sed -E 's/^s "//; s/"$//')

    if (( percent <= 10 )); then
        class="critical"
    elif (( percent <= 20 )); then
        class="warning"
    else
        class="normal"
    fi

    echo "{\"text\": \"${ICON} ${percent}%\", \"tooltip\": \"${name}\\n${percent}%\", \"class\": \"${class}\"}"
    exit 0
done

echo "$disconnected"
{{- end }}
