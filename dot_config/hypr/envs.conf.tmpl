# Extra env variables
# env = MY_GLOBAL_ENV,setting
# Put ~/.local/bin on Hyprland's exec PATH so bare script names in keybinds
# (e.g. toggle-claude-dropdown) resolve. bashrc adds it for interactive shells
# but Hyprland inherits PATH from the session manager, which does not.
env = PATH,$HOME/.local/bin:$PATH
{{- $host := index .hosts .chezmoi.hostname }}
{{- if eq $host.gpu "nvidia" }}
env = NVD_BACKEND,direct
env = LIBVA_DRIVER_NAME,nvidia
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
{{- end }}
