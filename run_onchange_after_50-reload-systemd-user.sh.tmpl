#!/usr/bin/env bash
# Runs when any managed user-systemd unit changes.
{{- $host := dict -}}
{{- if hasKey .hosts .chezmoi.hostname }}{{ $host = index .hosts .chezmoi.hostname }}{{ end -}}
{{- $host = merge $host .defaults }}
# Hash marker forces re-render when the enable list changes:
# enable-sha: {{ $host.systemd_user_enable | toYaml | sha256sum }}
set -euo pipefail

systemctl --user daemon-reload

{{ range $host.systemd_user_enable -}}
systemctl --user enable --now {{ . | quote }}
{{ end -}}
